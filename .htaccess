# ============================================================
# Bobr Studio — ЧПУ, кеширование и сжатие (Apache)
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Существующие файлы и директории отдаём напрямую
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Портфолио: /portfolio/{slug}
    RewriteRule ^portfolio/([A-Za-z0-9-]+)/?$ pages/project.php?slug=$1 [L,QSA]

    # Страницы раздела «Сайты»
    RewriteCond %{DOCUMENT_ROOT}/pages/sites/$1.php -f
    RewriteRule ^([A-Za-z0-9-]+)/?$ pages/sites/$1.php [L,QSA]

    # Остальные страницы
    RewriteCond %{DOCUMENT_ROOT}/pages/$1.php -f
    RewriteRule ^([A-Za-z0-9-]+)/?$ pages/$1.php [L,QSA]

    # Страницы в корне (например, index)
    RewriteRule ^([A-Za-z0-9-]+)/?$ $1.php [L,QSA]
</IfModule>

# ------------------------------------------------------------
# Gzip-сжатие
# ------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ------------------------------------------------------------
# Кеширование статики в браузере
# ------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png            "access plus 1 year"
    ExpiresByType image/jpeg           "access plus 1 year"
    ExpiresByType image/webp           "access plus 1 year"
    ExpiresByType image/svg+xml        "access plus 1 year"
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2           "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(png|jpe?g|webp|svg|css|js|woff2)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>
